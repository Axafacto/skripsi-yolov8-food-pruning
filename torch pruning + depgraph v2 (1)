,"\n","ax.bar(x-width/2, map50, width,\n","       label=\"mAP@0.5\")\n","ax.bar(x+width/2, map5095, width,\n","       label=\"mAP@0.5:0.95\")\n","\n","ax.set_xticks(x)\n","ax.set_xticklabels(labels)\n","ax.set_ylim(0,1.05)\n","ax.set_ylabel(\"mAP\")\n","ax.set_title(\"mAP pada Test Set\", fontweight=\"bold\")\n","ax.legend()\n","\n","for i,(a,b) in enumerate(zip(map50,map5095)):\n","    ax.text(i-width/2,a+0.02,f\"{a:.3f}\",ha=\"center\",fontsize=9)\n","    ax.text(i+width/2,b+0.02,f\"{b:.3f}\",ha=\"center\",fontsize=9)\n","\n","ax.spines[['top','right']].set_visible(False)\n","\n","# =====================================================\n","# 2. Parameter\n","# =====================================================\n","ax = axes[0,1]\n","\n","bars=ax.bar(labels,params/1e6)\n","\n","ax.set_ylabel(\"Parameter (Juta)\")\n","ax.set_title(\"Jumlah Parameter Model\",fontweight=\"bold\")\n","\n","for b,p,r in zip(bars,params,reduksi):\n","    ax.text(\n","        b.get_x()+b.get_width()/2,\n","        b.get_height()+0.15,\n","        f\"{p/1e6:.2f}M\\n(-{r:.1f}%)\",\n","        ha=\"center\",\n","        fontsize=9\n","    )\n","\n","ax.spines[['top','right']].set_visible(False)\n","\n","# =====================================================\n","# 3. Precision Recall\n","# =====================================================\n","ax=axes[1,0]\n","\n","ax.bar(x-width/2,precision,width,label=\"Precision\")\n","ax.bar(x+width/2,recall,width,label=\"Recall\")\n","\n","ax.set_xticks(x)\n","ax.set_xticklabels(labels)\n","ax.set_ylim(0,1.05)\n","ax.set_ylabel(\"Score\")\n","ax.set_title(\"Precision dan Recall (Test Set)\",fontweight=\"bold\")\n","ax.legend()\n","\n","for i,(p,r) in enumerate(zip(precision,recall)):\n","    ax.text(i-width/2,p+0.02,f\"{p:.3f}\",ha=\"center\",fontsize=9)\n","    ax.text(i+width/2,r+0.02,f\"{r:.3f}\",ha=\"center\",fontsize=9)\n","\n","ax.spines[['top','right']].set_visible(False)\n","\n","# =====================================================\n","