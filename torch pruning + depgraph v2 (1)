:["import ultralytics\n","print(ultralytics.__version__)"]},{"cell_type":"code","source":["# =========================================================\n","#  Mount GDrive\n","# =========================================================\n","from google.colab import drive\n","drive.mount('/content/drive')"],"metadata":{"colab":{"base_uri":"https://localhost:8080/"},"id":"-LoP_9YCqurS","executionInfo":{"status":"ok","timestamp":1784682132295,"user_tz":-420,"elapsed":22631,"user":{"displayName":"5040_ALDY ARDIANSYAH AZZAM","userId":"09263717343385334763"}},"outputId":"dd7772cd-d557-4458-c635-03e3ebf956ee"},"execution_count":3,"outputs":[{"output_type":"stream","name":"stdout","text":["Mounted at /content/drive\n"]}]},{"cell_type":"code","source":["#  CELL A — INSTALL & IMPORT\n","import torch\n","import torch.nn as nn\n","import torch_pruning as tp\n","import numpy as np\n","import os, time, shutil\n","from pathlib import Path\n","from copy import deepcopy\n","from ultralytics import YOLO\n","\n","DRIVE_BASE     = \"/content/drive/MyDrive/!Skripsi\"\n","DATA_YAML      = f\"{DRIVE_BASE}/Dataset/v2noAugment/data.yaml\"\n","BASELINE_PT    = f\"{DRIVE_BASE}/Results/yolov8s_v2/weights/best.pt\"\n","PRUNING_DIR    = f\"{DRIVE_BASE}/Pruning2\"\n","RATIOS         = [0.2, 0.3, 0.5]\n","DEVICE         = \"cuda\" if torch.cuda.is_available() else \"cpu\"\n","pruning_results = {}\n","\n","print(f\"  torch-pruning : {tp.__version__}\")\n","print(f\"  device        : {DEVICE}\")\n","\n"],"metadata":{"colab":{"base_uri":"https://localhost:8080/"},"id":"800_aJCSrn67","executionInfo":{"status":"ok","timestamp":1784682142123,"user_tz":-420,"elapsed":9831,"user":{"displayName":"5040_ALDY ARDIANSYAH AZZAM","userId":"09263717343385334763"}},"outputId":"0f43fb80-7dd2-4ba9-b6d8-57f68673d034"},"execution_count":4,"outputs":[{"output_type":"stream","name":"stdout","text":["  torch-pruning : 1.6.0\n","  device        : cuda\n"]}]},{"cell_type":"code","source":["# ════════════════════════════════════════════\n","#  CELL B — TORCH PRUNING (Ultralytics 8.4.66)\n","# ════════════════════════════════════════════\n","import math\n","import torch\n","import torch.nn as nn\n","from copy import deepcopy\n","from ultralytics import YOLO\n","from ultralytics.nn.modules import Detect, C2f, Conv, Bottleneck\n","from ultralytics.utils.torch_utils import initialize_weights\n","import torch_pruning as tp\n","\n","# ── C2f_v2 ──\n","class C2f_v2(nn.Module):\n","    def __init__(self, c1, c2, n=1, shortcut=False, g=1, e=0.5):\n","        super().__init__()\n","        self.c  = int(c2 * e)\n","        self.cv0 = Conv(c1, self.c, 1, 1)\n","        self.cv1 = Conv(c1, self.c, 1, 1)\n","        self.cv2 = Conv((2 + n) * self.c, c2, 1)\n","        self.m  = nn.ModuleList(\n","            Bottleneck(self.c, self.c, shortcut, g, k=((3,3),(3,3)), e=1.0)\n","            for _ in range(n)\n","        )\n","\n","    def forward(self, x):\n","        y = [self.cv0(x), self.cv1(x)]\n","        y.extend(m(y[-1]) for m in self.m)\n","        return self.cv2(torch.cat(y, 1))\n","\n","\n","def infer_shortcut(bottleneck):\n","    c1 = bottleneck.cv1.conv.in_channels\n","    c2 = bottleneck.cv2.conv.out_channels\n","    return c1 == c2 and hasattr(bottleneck, 'add') and bottleneck.add\n","\n","\n","def transfer_weights(c2f, c2f_v2):\n","    c2f_v2.cv2 = c2f.cv2\n","    c2f_v2.m   = c2f.m\n","    sd    = c2f.state_dict()\n","    sd_v2 = c2f_v2.state_dict()\n","    old_w = sd['cv1.conv.weight']\n","    half  = old_w.shape[0] // 2\n","    sd_v2['cv0.conv.weight'] = old_w[:half]\n","    sd_v2['cv1.conv.weight'] = old_w[half:]\n","    for k in ['weight', 'bias', 'running_mean', 'running_var']:\n","        old_bn = sd[f'cv1.bn.{k}']\n","        sd_v2[f'cv0.bn.{k}'] = old_bn[:half]\n","        sd_v2[f'cv1.bn.{k}'] = old_bn[half:]\n","    for key in sd:\n","        if not key.startswith('cv1.'):\n","            sd_v2[key] = sd[key]\n","    c2f_v2.load_state_dict(sd_v2)\n","\n","    # ← FIX: transfer atribut Ultralytics routing\n","    for attr in ['i', 'f', 'type']:\n","        if hasattr(c2f, attr):\n","            setattr(c2f_v2, attr, getattr(c2f, attr))\n","\n","\n","def replace_c2f_with_c2f_v2(module):\n","    for name, child in module.named_children():\n","        if isinstance(child, C2f):\n","            shortcut = infer_shortcut(child.m[0])\n","            new_mod  = C2f_v2(\n","                child.cv1.conv.in_channels,\n","                child.cv2.conv.out_channels,\n","                n=len(child.m),\n","                shortcut=shortcut,\n","                g=child.m[0].cv2.conv.groups,\n","                e=child.c / child.cv2.conv.out_channels\n","            )\n","            transfer_weights(child, new_mod)\n","            setattr(module, name, new_mod)\n","        else:\n","            replace_c2f_with_c2f_v2(child)\n","\n","\n","# ── Load model ──\n","print(\"Loading model...\")\n","yolo  = YOLO(BASELINE_PT)  # ← pakai baseline, bukan sparse\n","model = yolo.model.float().to(DEVICE)\n","model.train()\n","# ── Replace C2f → C2f_v2 ──\n","print(\"Replacing C2f with C2f_v2...\")\n","replace_c2f_with_c2f_v2(model)\n","initialize_weights(model)\n","model = model.to(DEVICE) #WITH GPU\n","\n","for _, param in model.named_parameters():\n","    param.requires_grad = True\n","\n","# ── Verifikasi forward pass ──\n","example_input = torch.zeros(1, 3, 640, 640).to(DEVICE)\n","with torch.no_grad():\n","    out = model(example_input)\n","print(\"✔ Forward pass OK setelah replace_c2f_with_c2f_v2\")\n","\n","# ── Baseline MACs & params ──\n","base_macs, base_params = tp.utils.count_ops_and_params(model, example_input)\n","print(f\"Baseline: MACs={base_macs/1e9:.3f}G, Params={base_params/1e6:.3f}M\")\n","\n","# ── Cek grup pruning ──\n","ignored_layers = [m for m in model.modules() if isinstance(m, Detect)]\n","\n","pruner = tp.pruner.GroupNormPruner(\n","    model,\n","    example_input,\n","    importance      = tp.importance.GroupMagnitudeImportance(),\n","    iterative_steps = 1,\n","    pruning_ratio   = 0.3,\n","    ignored_layers  = ignored_layers,\n",")\n","\n","print(\"\\nGrup pruning yang ditemukan:\")\n","total = 0\n","for group in pruner.step(interactive=True):\n","    total += 1\n","    if total <= 3:\n","        print(f\"  Group {total}: {group}\")\n","print(f\"\\nTotal grup: {total}\")"],"metadata":{"colab":{"base_uri":"https://localhost:8080/"},"id":"DRBQ69irtcJ1","executionInfo":{"status":"ok","timestamp":1784683457713,"user_tz":-420,"elapsed":1837,"user":{"displayName":"5040_ALDY ARDIANSYAH AZZAM","userId":"09263717343385334763"}},"outputId":"fc77a39e-9060-4a8e-cc6b-46839d3d8202"},"execution_count":19,"outputs":[{"output_type":"stream","name":"stdout","text":["Loading model...\n","Replacing C2f with C2f_v2...\n","✔ Forward pass OK setelah replace_c2f_with_c2f_v2\n","Baseline: MACs=14.290G, Params=11.143M\n","\n","Grup pruning yang ditemukan:\n","  Group 1: \n","--------------------------------\n","          Pruning Group\n","--------------------------------\n","[0] prune_out_channels on model.21.cv2.conv (Conv2d(768, 512, kernel_size=(1, 1), stride=(1, 1), bias=False)) => prune_out_channels on model.21.cv2.conv (Conv2d(768, 512, kernel_size=(1, 1), stride=(1, 1), bias=False)), len(idxs)=154\n","[1] prune_out_channels on model.21.cv2.conv (Conv2d(768, 512, kernel_size=(1, 1), stride=(1, 1), bias=False)) => prune_out_channels on model.21.cv2.bn (BatchNorm2d(512, eps=0.001, momentum=0.03, affine=True, track_running_stats=True)), len(idxs)=154\n","[2] prune_out_channels on model.21.cv2.bn (BatchNorm2d(512, eps=0.001, momentum=0.03, affine=True, track_running_stats=True)) => prune_out_channels on _ElementWiseOp_9(SiluBackward0), len(idxs)=154\n","[3] prune_out_channels on _ElementWiseOp_9(SiluBackward0) => prune_in_channels on model.22.cv3.2.0.conv (Conv2d(512, 128, kernel_size=(3, 3), stride=(1, 1), padding=(1, 1), bias=False)), len(idxs)=154\n","[4] prune_out_channels on _ElementWiseOp_9(SiluBackward0) => prune_in_channels on model.22.cv2.2.0.conv (Conv2d(512, 64, kernel_size=(3, 3), stride=(1, 1), padding=(1, 1), bias=False)), len(idxs)=154\n","--------------------------------\n","\n","  Group 2: \n","--------------------------------\n","          Pruning Group\n","--------------------------------\n","[0] prune_out_channels on model.21.m.0.cv2.conv (Conv2d(256, 256, kernel_size=(3, 3), stride=(1, 1), padding=(1, 1), bias=False)) => prune_out_channels on model.21.m.0.cv2.conv (Conv2d(256, 256, kernel_size=(3, 3), stride=(1, 1), padding=(1, 1), bias=False)), len(idxs)=77\n","[1] prune_out_channels on model.21.m.0.cv2.conv (Conv2d(256, 256, kernel_size=(3, 3), stride=(1, 1), padding=(1, 1), bias=False)) => prune_out_channels on model.21.m.0.cv2.bn (BatchNorm2d(256, eps=0.001, momentum=0.03, affine=True, track_running_stats=True)), len(idxs)=77\n","[2] prune_out_channels on model.21.m.0.cv2.bn (BatchNorm2d(256, eps=0.001, momentum=0.03, affine=True, track_running_stats=True)) => prune_out_channels on _ElementWiseOp_13(SiluBackward0), len(idxs)=77\n","[3] prune_out_channels on _ElementWiseOp_13(SiluBackward0) => prune_out_channels on _ConcatOp_10([0, 256, 512, 768]), len(idxs)=77\n","[4] prune_out_channels on _ConcatOp_10([0, 256, 512, 768]) => prune_in_channels on model.21.cv2.conv (Conv2d(768, 512, kernel_size=(1, 1), stride=(1, 1), bias=False)), len(idxs)=77\n","--------------------------------\n","\n","  Group 3: \n","--------------------------------\n","          Pruning Group\n","--------------------------------\n","[0] prune_out_channels on model.21.m.0.cv1.conv (Conv2d(256, 256, kernel_size=(3, 3), stride=(1, 1), padding=(1, 1), bias=False)) => prune_out_channels on model.21.m.0.cv1.conv (Conv2d(256, 256, kernel_size=(3, 3), stride=(1, 1), padding=(1, 1), bias=False)), len(idxs)=77\n","[1] prune_out_channels on model.21.m.0.cv1.conv (Conv2d(256, 256, kernel_size=(3, 3), stride=(1, 1), padding=(1, 1), bias=False)) => prune_out_channels on model.21.m.0.cv1.bn (BatchNorm2d(256, eps=0.001, momentum=0.03, affine=True, track_running_stats=True)), len(idxs)=77\n","[2] prune_out_channels on model.21.m.0.cv1.bn (BatchNorm2d(256, eps=0.001, momentum=0.03, affine=True, track_running_stats=True)) => prune_out_channels on _ElementWiseOp_14(SiluBackward0), len(idxs)=77\n","[3] prune_out_channels on _ElementWiseOp_14(SiluBackward0) => prune_in_channels on model.21.m.0.cv2.conv (Conv2d(256, 256, kernel_size=(3, 3), stride=(1, 1), padding=(1, 1), bias=False)), len(idxs)=77\n","--------------------------------\n","\n","\n","Total grup: 47\n"]}]},{"cell_type":"code","source":["# CELL — BUKTI VISUAL: VERIFIKASI MODUL C2f SUDAH BERUBAH JADI C2f_v2\n","\n","# 1. Cara paling ringkas — cek tipe modul langsung\n","print(\"Cek beberapa modul C2f_v2 pertama yang ditemukan:\\n\")\n","count = 0\n","for name, module in model.named_modules():\n","    if isinstance(module, C2f_v2):\n","        count += 1\n","        print(f\"{name}: {module.__class__.__name__}\")\n","        if count >= 5:  # cukup 5 contoh saja biar tidak kepanjangan\n","            break\n","\n","print(f\"\\nTotal modul C2f_v2 ditemukan di model: {sum(1 for m in model.modules() if isinstance(m, C2f_v2))}\")\n","\n","# 2. Verifikasi eksplisit cv0 dan cv1 terpisah (bukti struktural utama)\n","print(\"\\nContoh struktur salah satu C2f_v2 (menunjukkan cv0 dan cv1 sebagai layer terpisah):\\n\")\n","for name, module in model.named_modules():\n","    if isinstance(module, C2f_v2):\n","        print(module)\n","        break  # cukup 1 contoh"],"metadata":{"colab":{"base_uri":"https://localhost:8080/"},"id":"T0m2KtRlYoqk","executionInfo":{"status":"ok","timestamp":1784682812598,"user_tz":-420,"elapsed":53,"user":{"displayName":"5040_ALDY ARDIANSYAH AZZAM","userId":"09263717343385334763"}},"outputId":"3beb74fd-0d0f-4f81-ef3a-c849f15f9dc5"},"execution_count":12,"outputs":[{"output_type":"stream","name":"stdout","text":["Cek beberapa modul C2f_v2 pertama yang ditemukan:\n","\n","model.model.2: 