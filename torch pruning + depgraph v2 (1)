=82 — ambil dari info fused\n","    info = model_obj.model.info(verbose=False)\n","    # pakai dari val summary saja, hardcode per model\n","\n","    # GFLOPs via thop, konsisten dengan baseline\n","    try:\n","        from thop import profile\n","        model_inner = model_obj.model\n","        dummy_thop  = torch.zeros(1, 3, 640, 640).to(\n","                          next(model_inner.parameters()).device)\n","        macs, _  = profile(model_inner, inputs=(dummy_thop,), verbose=False)\n","        gflops   = macs * 2 / 1e9\n","    except:\n","        gflops = float('nan')\n","\n","    # Parameter count\n","    n_params = sum(p_.numel() for p_ in model_obj.model.parameters())\n","\n","    # Ukuran file\n","    weight_size_mb = Path(weight_path).stat().st_size / (1024**2)\n","\n","    # Inference time\n","    dummy = torch.zeros(1, 3, 640, 640)\n","    times = []\n","    for _ in range(20):\n","        t0 = time.perf_counter()\n","        model_obj.predict(source=dummy, verbose=False, device=DEVICE)\n","        times.append((time.perf_counter() - t0) * 1000)\n","    times   = times[5:]\n","    elapsed = np.mean(times)\n","    fps     = 1000 / elapsed\n","\n","    return {\n","        \"Model\"                  : name,\n","        \"Jumlah Parameter\"       : n_params,\n","        \"GFLOPs\"                 : round(gflops, 1),\n","        \"Ukuran Bobot (MB)\"      : round(weight_size_mb, 2),\n","        \"Epochs\"                 : epochs,\n","        \"Precision (Test)\"       : round(p, 4),\n","        \"Recall (Test)\"          : round(r, 4),\n","        \"F1-score (Test)\"        : round(f1, 4),\n","        \"mAP@0.5 (Test)\"         : round(map50, 4),\n","        \"mAP@0.5:0.95 (Test)\"    : round(map5095, 4),\n","        \"Inferensi (ms/img)\"     : round(elapsed, 2),\n","        \"FPS\"                    : round(fps, 1),\n","    }\n","\n","\n","all_results = []\n","\n","# Baseline\n","print(\"── Evaluasi Baseline (Test Set) ──\")\n","baseline_model = YOLO(BASELINE_PT)\n","all_results.append(evaluate_model(baseline_model, \"Baseline (YOLOv8s)\",\n","                                  BASELINE_PT, 100))\n","\n","# Pruned + Fine-tuned\n","for ratio in [0.2, 0.3, 0.5]:\n","    pct = int(ratio*100)\n","    print(f\"\\n── Evaluasi Pruned {pct}% (Test Set) ──\")\n","\n","    ckpt = torch.load(finetuned_paths[ratio], map_location=DEVICE,\n","                      weights_only=False)\n","    pruned_model = ckpt['model'].float().to(DEVICE)\n","    pruned_model.eval()\n","\n","    yolo_val       = YOLO(BASELINE_PT)\n","    yolo_val.model = pruned_model\n","\n","    all_results.append(evaluate_model(yolo_val, f\"Pruned {pct}%\",\n","                                      finetuned_paths[ratio], 100))\n","\n","df = pd.DataFrame(all_results)\n","print(\"\\n\" + \"=\"*80)\n","print(df.to_string(index=False))\n","\n","out_csv = f\"{PRUNING_DIR}/ringkasan_evaluasi_pruning.csv\"\n","df.to_csv(out_csv, index=False)\n","print(f\"\\n✔ Disimpan: {out_csv}\")"],"metadata":{"colab":{"base_uri":"https://localhost:8080/"},"id":"k4PUJTV4DXyu","executionInfo":{"status":"ok","timestamp":1782058139165,"user_tz":-420,"elapsed":33069,"user":{"displayName":"5040_ALDY ARDIANSYAH AZZAM","userId":"09263717343385334763"}},"outputId":"710869c8-5d6c-46a2-f858-fe6a2f02f2c9"},"execution_count":null,"outputs":[{"output_type":"stream","name":"stdout","text":["── Evaluasi Baseline (Test Set) ──\n","Ultralytics 8.4.73 🚀 Python-3.12.13 torch-2.11.0+cu128 CUDA:0 (Tesla T4, 14913MiB)\n","Model summary (fused): 73 layers, 11,132,550 parameters, 0 gradients, 28.5 GFLOPs\n","\u001b[34m\u001b[1mval: \u001b[0mFast image access ✅ (ping: 0.8±0.3 ms, read: 28.9±10.3 MB/s, size: 56.9 KB)\n","\u001b[K\u001b[34m\u001b[1mval: \u001b[0mScanning /content/drive/MyDrive/!Skripsi/Dataset/v2noAugment/test/labels.cache... 68 images, 0 backgrounds, 0 corrupt: 100% ━━━━━━━━━━━━ 68/68 25.9Mit/s 0.0s\n","\u001b[K                 Class     Images  Instances      Box(P          R      mAP50